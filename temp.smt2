(declare-sort Tensor 0)
(declare-fun MulScalarScalar (Int Int) Int)
(declare-fun AddScalarScalar (Int Int) Int)
(declare-fun operation (Int Int) Int)
(declare-fun E_extra (Tensor) Int)
(declare-fun E (Tensor) Int)
(declare-fun R2 (Tensor) Tensor)
(declare-fun R1 (Tensor) Tensor)
(declare-fun MulTensorTensor (Tensor Tensor) Tensor)
(declare-fun AddScalarTensor (Int Tensor) Tensor)
(declare-fun AddTensorTensor (Tensor Tensor) Tensor)
(declare-fun MulScalarTensor (Int Tensor) Tensor)
(declare-fun B0 () Tensor)
(declare-fun u0 () Int)
(declare-fun v0 () Int)
(assert (forall ((a Int) (b Int)) (= (MulScalarScalar a b) (* a b))))
(assert (forall ((a Int) (b Int)) (= (MulScalarScalar a b) (MulScalarScalar b a))))
(assert (forall ((a Int) (b Int)) (= (AddScalarScalar a b) (+ a b))))
(assert (forall ((a Int) (b Int)) (= (AddScalarScalar a b) (AddScalarScalar b a))))
(assert (forall ((t Tensor)) (= (E (R1 t)) (operation (E (R2 t)) (E_extra t)))))
(assert (forall ((T_base Tensor)) (= (R1 T_base) (R2 T_base))))
(assert (forall ((B Tensor) (v Int) (u Int))
  (= (AddScalarTensor v (AddScalarTensor v (R2 B)))
     (MulTensorTensor (AddScalarTensor u B) (R2 B)))))
(assert (forall ((f Tensor) (g Tensor))
  (= (E (AddTensorTensor f g)) (AddScalarScalar (E f) (E g)))))
(assert (forall ((f Tensor) (v Int))
  (= (E (AddScalarTensor v f)) (AddScalarScalar v (E f)))))
(assert (forall ((f Tensor) (g Tensor))
  (= (E (MulTensorTensor f g)) (MulScalarScalar (E f) (E g)))))
(assert (forall ((f Tensor) (v Int))
  (= (E (MulScalarTensor v f)) (MulScalarScalar v (E f)))))
(assert (forall ((f Tensor) (g Tensor))
  (= (E_extra (AddTensorTensor f g)) (AddScalarScalar (E_extra f) (E_extra g)))))
(assert (forall ((f Tensor) (v Int))
  (= (E_extra (AddScalarTensor v f)) (AddScalarScalar v (E_extra f)))))
(assert (forall ((f Tensor) (g Tensor))
  (= (E_extra (MulTensorTensor f g)) (MulScalarScalar (E_extra f) (E_extra g)))))
(assert (forall ((f Tensor) (v Int))
  (= (E_extra (MulScalarTensor v f)) (MulScalarScalar v (E_extra f)))))
(assert (forall ((a Int) (b Int)) (= (operation a b) (AddScalarScalar a b))))
(assert (forall ((a Int) (b Int) (c Int))
  (= (operation (MulScalarScalar a c) (MulScalarScalar b c))
     (MulScalarScalar (operation a b) c))))
(assert (forall ((a Int) (b Int) (C Tensor))
  (= (MulScalarTensor a (AddScalarTensor b C))
     (AddScalarTensor (MulScalarScalar a b) (MulScalarTensor a C)))))
(assert (forall ((f Tensor) (g Tensor)) (= (AddTensorTensor f g) (AddTensorTensor g f))))
(assert (forall ((f Tensor) (g Tensor)) (= (MulTensorTensor f g) (MulTensorTensor g f))))
(assert (forall ((f Tensor) (g Tensor) (h Tensor))
  (= (AddTensorTensor (AddTensorTensor f g) h)
     (AddTensorTensor f (AddTensorTensor g h)))))
(assert (forall ((f Tensor) (g Tensor) (h Tensor))
  (= (MulTensorTensor (MulTensorTensor f g) h)
     (MulTensorTensor f (MulTensorTensor g h)))))
(assert (forall ((a Int) (f Tensor) (g Tensor))
  (= (MulScalarTensor a (AddTensorTensor f g))
     (AddTensorTensor (MulScalarTensor a f) (MulScalarTensor a g)))))
(assert (forall ((f Tensor) (g Tensor) (h Tensor))
  (= (MulTensorTensor f (AddTensorTensor g h))
     (AddTensorTensor (MulTensorTensor f g) (MulTensorTensor f h)))))
(assert (forall ((a Int) (b Int) (c Int))
  (= (MulScalarScalar (AddScalarScalar a b) c)
     (AddScalarScalar (MulScalarScalar a c) (MulScalarScalar b c)))))
(assert (forall ((a Int) (b Int) (c Int))
  (= (MulScalarScalar (MulScalarScalar a b) c)
     (MulScalarScalar a (MulScalarScalar b c)))))
(assert (forall ((a Int) (b Int) (c Int))
  (= (AddScalarScalar (AddScalarScalar a b) c)
     (AddScalarScalar a (AddScalarScalar b c)))))
(assert (let ((a!1 (E (AddScalarTensor v0 (AddScalarTensor v0 (R2 B0))))))
(let ((a!2 (= a!1 (E (MulTensorTensor (AddScalarTensor u0 B0) (R2 B0))))))
  (not a!2))))

